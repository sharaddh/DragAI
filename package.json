{
  "name": "@anomalyco/component-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Zero-dependency React component generator — converts text prompts and screenshots into production-ready JSX+PropTypes components using pixel-level image analysis, no external LLM",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jimp": "^1.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.21.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "react",
    "component-generator",
    "tailwind",
    "proptypes",
    "no-llm",
    "image-analysis",
    "jimp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/opencode.git"
  }
}
